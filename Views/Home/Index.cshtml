<div class="section-divider"></div>
<section class="popular-section">
    <div class="section-header">
        <h2>Популярные экскурсии</h2>
        <p>Выберите своё приключение</p>
    </div>

    <div class="popular-grid">
        @foreach (ServiceDTO entity in Model.Take(6))
        {
            <div class="popular-card">
                <div class="tour-card">
                   @*  <!-- Бейдж скидки -->
                    <div class="tour-badge">Топ<br>-20%</div> *@

                    <!-- Изображение -->
                    <div class="tour-image">
                        <img src="~/img/@entity.PhotoFileName" alt="@entity.Title" />
                    </div>

                    <!-- Заголовок -->
                    <h3 class="tour-title">@entity.Title</h3>

                    <!-- Характеристики -->
                    <div class="tour-meta">
                        <span>⏱ @entity.Time часов</span>
                        @* <span>🚐 Автобус</span> *@
                        @* <span>📍 @entity.Distance км</span> *@
                    </div>

                    <!-- Описание -->
                    <div class="tour-description">
                        <p class="tour-short-desc">@entity.DescriptionShort</p>
                    </div>

                    <!-- Рейтинг -->
                    <div class="tour-rating">
                        <span class="stars">★★★★★</span>
                        <span class="rating-value">5.0</span>
                        @* <span class="reviews">(@entity.Reviews отзывов)</span> *@
                    </div>

                    <!-- Цены -->
                    <div class="tour-prices">
                        <div class="price-row">
                            <span class="price-label">Взр:</span>
                            <span class="price-new">от $@entity.Price</span>
                            
                            
                        </div>
                        <div class="price-row">
                            <span class="price-label">Реб:</span>
                            <span class="price-new">от $@entity.Price</span>
                            
                            
                        </div>
                    </div>

                    <!-- Кнопка -->
                    <a asp-controller="Services" asp-action="Show" asp-route-id="@entity.Id" class="tour-btn">
                        Подробнее →
                    </a>
                </div>

                    
                </div>
           
        }
    </div>

    <div class="section-footer">
        <a asp-controller="Services" asp-action="Index" class="btn-all">
            Смотреть все экскурсии →
        </a>
    </div>
</section>

<script>
    let currentSlide = 0;
    const slides = document.querySelectorAll('.hero-slider .slide');

    function nextSlide() {
        slides[currentSlide].classList.remove('active');
        currentSlide = (currentSlide + 1) % slides.length;
        slides[currentSlide].classList.add('active');
    }

    setInterval(nextSlide, 5000);
</script>
<script>
    // Плавное появление фона хедера при скролле
    window.addEventListener('scroll', function() {
        var header = document.getElementById('header-wrapper');
        if (window.scrollY > 50) {
            header.classList.add('scrolled');
        } else {
            header.classList.remove('scrolled');
        }
    });
</script>